      "parameters": {
        "jsCode": "const output = items[0].json.output;\n\nconst tagIndex = output.indexOf('BOOKING_COMPLETE:');\n\nlet cleanMessage = output;\nlet bookingData = null;\n\nif (tagIndex !== -1) {\n  cleanMessage = output.substring(0, tagIndex).trim();\n  const jsonString = output.substring(tagIndex + 'BOOKING_COMPLETE:'.length).trim();\n  try {\n    bookingData = JSON.parse(jsonString);\n    bookingData.matchingEmail = bookingData.old_email || bookingData.email;\n  } catch(e) {\n    bookingData = null;\n  }\n}\n\nitems[0].json.output = cleanMessage;\nitems[0].json.bookingData = bookingData;\nitems[0].json.isComplete = bookingData !== null;\n\nreturn items;"
      },
